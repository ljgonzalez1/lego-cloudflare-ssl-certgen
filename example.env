# ==============================================================================
# example.env  --  Sample configuration for lego-cloudflare-certgen
# ==============================================================================
# Edit this file with real values and pass it to the container at runtime.
#
# docker run (token passed separately, never in the env-file):
#   docker run --rm \
#     --env-file ./example.env \
#     --env CLOUDFLARE_API_KEY="${CLOUDFLARE_API_KEY}" \
#     --volume "$(pwd)/ssl-certs:/ssl-certs" \
#     --security-opt no-new-privileges:true \
#     --cap-drop ALL --cap-add CHOWN --cap-add SETUID --cap-add SETGID \
#     lego-cloudflare-certgen:lego4.34.0-v0.1
#
# docker compose (token passed as Docker secret — see docker-compose.yml):
#   docker compose run --rm certgen
# ==============================================================================

# Timezone for log timestamps and output directory names.
# Must be a valid IANA timezone name.
# Examples: Etc/UTC  America/Santiago  Europe/London  Asia/Tokyo
# Default: Etc/UTC
TZ=America/Santiago

# Contact e-mail registered with Let's Encrypt.
# Used for account creation and certificate expiry notifications.
# Required.
EMAIL=user@example.com

# Issue real, browser-trusted certificates.
# false -- Let's Encrypt staging (not trusted; relaxed rate limits; safe for testing)
# true  -- production certificates (rate limit: 5 per registered domain per week)
# Default: false
PRODUCTION=false

# Comma-separated list of domain names to include in the certificate.
# Wildcards (*.domain.tld) are supported via DNS-01 challenge.
# No spaces. No trailing comma.
#
# When using --env on the command line, always quote the value to prevent
# the shell from glob-expanding the asterisk:
#   --env 'DOMAINS=*.example.com,example.com'   <- safe (single quotes)
#   --env DOMAINS="*.example.com,example.com"   <- safe if no matching files
# When using --env-file, no quoting is needed; Docker reads the file literally.
DOMAINS=*.example.com,example.com,*.sub.example.com

# Cloudflare DNS API token with Zone > DNS > Edit permission.
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Required — provide via --env or Docker secret, not this file.
# See docker-compose.yml for the recommended secrets-based approach.
CLOUDFLARE_API_KEY=

# Number of seconds to wait for DNS TXT record propagation before notifying
# Let's Encrypt to validate.  Increase if validation fails with timeout errors.
# Default: 60
PROPAGATION_SECONDS=60

# DNS resolvers used by lego to verify that the TXT record is publicly visible.
# Comma-separated list of host:port pairs.
# Default: 1.1.1.1:53,8.8.8.8:53,1.0.0.1:53  (Cloudflare primary/secondary + Google)
DNS_RESOLVERS=1.1.1.1:53,8.8.8.8:53,1.0.0.1:53

# Accept the Let's Encrypt Terms of Service.
# Must be explicitly set to 'true'. Certificate generation will fail otherwise.
# Review the TOS at: https://letsencrypt.org/repository/
# Default: false
ACCEPT_LEGO_TOS=false

# UID and GID for certificate file ownership on the host volume.
# Set these to match the user that will read the certificates on the host.
# Must be non-zero. Default: 1000
UID=1001
GID=1002
