# ==============================================================================
# template.env  --  Configuration template for lego-cloudflare-certgen
# ==============================================================================
# Domain names are NOT configured in this file.
# Create ./domains.txt and mount it as /domains.txt:ro.

# Timezone (IANA format).  Default: Etc/UTC
# Examples: America/Santiago  Europe/London  Asia/Tokyo
TZ=

# Contact e-mail for the Let's Encrypt account.  Required.
EMAIL=

# Issue real certificates.  Default: false (staging)
# WARNING: rate limit of 5 duplicate certificates per registered domain per week
# in production.
PRODUCTION=

# Cloudflare DNS API token.  Required.
# Recommended with docker run: pass via --env CLOUDFLARE_API_KEY="..." instead
# of storing it in this file.
# Docker Compose may also provide it as /run/secrets/cloudflare_api_token.
CLOUDFLARE_API_KEY=

# DNS propagation wait time in seconds.  Default: 60
PROPAGATION_SECONDS=

# DNS resolvers for propagation verification (host:port, comma-separated).
# Default: 1.1.1.1:53,8.8.8.8:53,1.0.0.1:53
DNS_RESOLVERS=

# Accept Let's Encrypt Terms of Service.  Must be 'true'.  Required.
# See: https://letsencrypt.org/repository/
ACCEPT_LEGO_TOS=

# Certificate file ownership (UID/GID).  Default: 1000
# Must be non-zero.  Set to match the user that reads the certs on the host.
UID=
GID=
