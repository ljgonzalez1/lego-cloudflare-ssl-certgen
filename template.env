# ==============================================================================
# template.env  --  Configuration template for lego-cloudflare-certgen
# ==============================================================================
# Copy this file, fill in the required values, and pass it to the container.
#
#   cp template.env certgen.env
#   # Edit certgen.env
#   docker compose run --rm certgen          # recommended (uses Docker secret)
#   docker run --rm --env-file ./certgen.env --env CLOUDFLARE_API_KEY="${CLOUDFLARE_API_KEY}" ...
#
# Do NOT commit certgen.env or .env to version control.
# Add them to .gitignore:
#   echo "certgen.env" >> .gitignore
#   echo ".env"        >> .gitignore
#   echo "ssl-certs/"  >> .gitignore
# ==============================================================================

# Timezone (IANA format).  Default: Etc/UTC
# Examples: America/Santiago  Europe/London  Asia/Tokyo
TZ=

# Contact e-mail for the Let's Encrypt account.  Required.
EMAIL=

# Issue real certificates.  Default: false (staging)
# WARNING: rate limit of 5 certificates per registered domain per week in production.
PRODUCTION=

# Comma-separated domain list.  Required.
# Wildcards supported (e.g. *.example.com).  No spaces.
# Quote the value when using --env:  --env 'DOMAINS=*.example.com,...'
DOMAINS=

# Cloudflare DNS API token.  Required.
# Provide via --env or Docker secret (docker-compose.yml), not this file.
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_KEY=

# DNS propagation wait time in seconds.  Default: 60
PROPAGATION_SECONDS=

# DNS resolvers for propagation verification (host:port, comma-separated).
# Default: 1.1.1.1:53,8.8.8.8:53,1.0.0.1:53
DNS_RESOLVERS=

# Accept Let's Encrypt Terms of Service.  Must be 'true'.  Required.
# See: https://letsencrypt.org/repository/
ACCEPT_LEGO_TOS=

# Certificate file ownership (UID/GID).  Default: 1000
# Must be non-zero.  Set to match the user that reads the certs on the host.
UID=
GID=
